# ============================================================
#  Git 忽略规则 - RentManageSystem
#  用于排除不需要纳入版本控制的文件
# ============================================================

# ---------- 编译输出 ----------
target/
*.class
*.jar
*.war
*.log

# ---------- IDE 配置 ----------
.idea/
*.iml
*.iws
*.ipr
.vscode/
settings.xml

# ---------- Maven Wrapper ----------
.mvn/
mvnw.cmd
!mvnw

# ---------- 操作系统文件 ----------
.DS_Store
Thumbs.db
Desktop.ini

# ---------- 环境配置（包含敏感信息）----------
application-local.yml
.env
*.env.local

# ---------- 上传的文件（图片等）----------
# 忽略上传的图片文件，但保留目录结构（通过 .gitkeep）
uploads/house/*/
uploads/house/*.jpg
uploads/house/*.jpeg
uploads/house/*.png
uploads/house/*.webp
!uploads/house/.gitkeep
static/uploads/

# ---------- 日志文件 ----------
logs/
*.log
nohup.out

# ---------- 临时文件 ----------
*.tmp
*.bak
*.swp
*~
