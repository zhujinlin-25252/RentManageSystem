# ============================================================
#  Git 忽略规则
#  只记录重要源码，排除编译产物 / 依赖 / IDE配置 / 临时文件
# ============================================================

# ---------- IDE 配置 ----------
.idea/
.vscode/
*.iml
*.iws
*.ipr

# ---------- 工具数据 ----------
.workbuddy/

# ---------- 编译输出 ----------
target/
dist/
*.class
*.jar
*.war

# ---------- 依赖目录 ----------
node_modules/
.vite/

# ---------- Maven Wrapper（保留 mvnw 脚本）----------
.mvn/
mvnw.cmd
!mvnw

# ---------- 操作系统文件 ----------
.DS_Store
Thumbs.db
Desktop.ini

# ---------- 环境配置（含敏感信息）----------
application-local.yml
.env
*.env.local
settings.xml

# ---------- 调试 & 计划文件 ----------
Plan/

# ---------- 文档 ----------
青年品质租房管理系统软件需求分析/

# ---------- 日志 ----------
logs/
*.log
nohup.out

# ---------- 临时文件 ----------
*.tmp
*.bak
*.swp
*~

# ---------- 压缩包 ----------
*.zip
*.tar.gz
*.rar
*.7z
